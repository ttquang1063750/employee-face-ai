# Copy this file to .env and fill in real values. .env is gitignored —
# never commit actual credentials. Both db.py (via python-dotenv) and
# docker-compose.yml read these same variable names.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mysecretpassword
POSTGRES_DB=employee_face_ai

# Login for the one admin account db.py bootstraps when the employees table
# is empty (see bootstrap_admin_account in db.py) — change these before
# deploying anywhere real.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
