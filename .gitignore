# Employee reference photos (sensitive personal data) & AI model cache
# (anchored to repo root — an unanchored `database/`/`documents/` also
# matched frontend/src/app/pages/admin/documents/, silently untracking that
# entire Angular feature folder; verify with `git status --ignored` after
# touching these lines)
/database/

# Captured audit photos (runtime data)
/logs/

# Uploaded HR documents (sensitive — payroll/contracts, runtime data)
/documents/

